{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.voiceintel.app",
  "app": {
    "windows": [
      {
        "title": "Voice Intelligence",
        "width": 800,
        "height": 600,
        "devtools": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; media-src 'self' blob: mediastream:;"
    }
  },
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false
  }
}